---
import { pricing } from '@lib/site';
---

<section class="section pricing-section" id="precios">
  <div class="container">
    <header class="pricing-head">
      <span class="eyebrow pricing-eyebrow">
        <span class="pricing-live"></span> Planes claros · sin sorpresas
      </span>
      <h2 class="display">
        Una cuota clara. <span class="pricing-head-muted">Nada escondido.</span>
      </h2>
      <p class="pricing-lede">
        Sin inversión inicial, sin permanencia, IVA aparte. Dominio, hosting,
        correos y mantenimiento <strong>siempre incluidos</strong>.
      </p>
    </header>

    <div class="pricing-grid">
      {pricing.map((tier) => (
        <article class={`tier reveal accent-${tier.accent} ${tier.highlight ? 'is-highlight' : ''}`}>
          {tier.badge && <span class="tier-badge">{tier.badge}</span>}
          <div class="tier-top">
            <h3 class="tier-name">{tier.name}</h3>
            <p class="tier-caption">{tier.caption}</p>
          </div>
          <div class="tier-price">
            {tier.priceFrom && <span class="tier-from">desde</span>}
            <span class="tier-amount">{tier.price}</span>
            <span class="tier-currency">€</span>
            <span class="tier-period">/ mes</span>
          </div>
          {tier.oneTime && (
            <div class="tier-original">
              o <strong>{tier.oneTime}€</strong> en pago único
            </div>
          )}
          <ul class="tier-features">
            {tier.features.map((f) => <li>{f}</li>)}
          </ul>
          <a class={`btn ${tier.highlight ? 'btn-primary' : 'btn-ghost'}`} href="/contacto/">
            {tier.cta} →
          </a>
        </article>
      ))}
    </div>

    <p class="pricing-foot">
      ¿Proyecto fuera de estas cajas?
      <a href="/contacto/">Te hacemos un traje a medida</a>.
    </p>
  </div>
</section>

<style>
  .pricing-section {
    background:
      radial-gradient(circle at 10% 10%, color-mix(in srgb, var(--purple-100) 60%, transparent), transparent 45%),
      radial-gradient(circle at 90% 90%, color-mix(in srgb, var(--orange-100) 60%, transparent), transparent 45%),
      var(--paper);
  }
  .pricing-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    max-width: 60ch;
    margin-bottom: var(--s-8);
  }
  .pricing-head h2 { font-size: var(--fs-h1); }
  .pricing-head-muted { color: var(--ink-40); }
  .pricing-lede { color: var(--ink-60); font-size: var(--fs-md); max-width: 50ch; }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--s-4);
    align-items: stretch;
  }

  .tier {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    padding: var(--s-6);
    background: var(--c-bg-elev);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    transition: transform var(--dur-3) var(--ease-out-expo),
                box-shadow var(--dur-3) var(--ease-out-expo),
                border-color var(--dur-2);
  }
  .tier:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent, var(--purple-500));
  }

  .tier.is-highlight {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .tier.is-highlight:hover { border-color: var(--accent); }

  .tier-badge {
    position: absolute;
    top: -12px;
    z-index: 2;
    left: 50%;
    transform: translateX(-50%);
    max-width: calc(100% - var(--s-5));
    background: var(--accent, var(--pink-500));
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-weight: 600;
    white-space: nowrap;
  }

  .pricing-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 0.4rem 0.9rem;
    background: color-mix(in srgb, var(--pink-500) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--pink-500) 30%, transparent);
    border-radius: 999px;
    color: var(--pink-700);
    font-weight: 600;
    width: max-content;
  }
  .pricing-live {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--pink-500);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--pink-500) 25%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  .pricing-lede strong {
    color: var(--ink);
    font-weight: 600;
    border-bottom: 2px solid var(--pink-500);
  }

  .tier-original {
    font-size: var(--fs-xs);
    color: color-mix(in srgb, currentColor 60%, transparent);
    margin-top: calc(var(--s-2) * -1);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-snug);
  }
  .tier-original s {
    color: color-mix(in srgb, currentColor 70%, transparent);
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
  }

  .tier-top {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    padding-bottom: var(--s-4);
    border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }
  .tier-name {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-variation-settings: 'opsz' 72, 'SOFT' 40;
    letter-spacing: -0.01em;
  }
  .tier-caption {
    font-size: var(--fs-sm);
    color: color-mix(in srgb, currentColor 65%, transparent);
    line-height: var(--lh-snug);
  }

  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
  }
  .tier-from {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: color-mix(in srgb, currentColor 60%, transparent);
    margin-right: 4px;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .tier-amount { font-size: clamp(2.5rem, 7vw, 3.5rem); font-weight: 500; line-height: 1; }
  .tier-currency { font-size: 1.5rem; font-weight: 500; margin-left: 2px; }
  .tier-period {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: color-mix(in srgb, currentColor 55%, transparent);
    margin-left: 4px;
  }

  .tier-features {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    flex: 1;
  }
  .tier-features li {
    font-size: var(--fs-sm);
    color: color-mix(in srgb, currentColor 80%, transparent);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .tier-features li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.55em;
    width: 8px; height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  .tier .btn { margin-top: auto; justify-content: center; }
  .tier.is-highlight .btn-primary {
    background: var(--paper);
    color: var(--ink);
  }
  .tier.is-highlight .btn-primary:hover {
    background: var(--accent);
    color: var(--white);
  }

  .accent-purple { --accent: var(--purple-500); }
  .accent-pink   { --accent: var(--pink-500); }
  .accent-orange { --accent: var(--orange-500); }
  .accent-blue   { --accent: var(--blue-500); }

  .pricing-foot {
    text-align: center;
    margin-top: var(--s-7);
    color: var(--ink-60);
    font-size: var(--fs-sm);
  }
  .pricing-foot a {
    color: var(--ink);
    border-bottom: 1px solid var(--ink-20);
  }
  .pricing-foot a:hover { border-bottom-color: var(--purple-500); color: var(--purple-500); }

  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
</style>
