---
import { site } from '@lib/site';
---

<section class="section group-atenea-section" aria-labelledby="group-atenea-heading">
  <div class="group-atenea-wrap">
    <div class="group-atenea-content">
      <div class="group-atenea-eyebrow">
        <span class="group-atenea-dot"></span>
        <span>04 · Nuestro estudio hermano</span>
      </div>
      <h2 id="group-atenea-heading">
        ¿Y si <em>además</em> de diseñarla,<br>también te la protegemos?
      </h2>
      <p class="group-atenea-lede">
        Compartimos fundador y filosofía: <strong>{site.sister.name}</strong> audita, endurece
        y forma a las mismas PYMEs que diseñamos. Pentesting, auditorías técnicas, MDR
        gestionado y cumplimiento NIS2/ENS. Una llamada, dos estudios, cero reuniones duplicadas.
      </p>
      <div class="group-atenea-feats">
        <span>Pentesting web</span>
        <span>Auditorías técnicas</span>
        <span>MDR 24/7</span>
        <span>NIS2 &amp; ENS</span>
      </div>
      <div class="group-atenea-buttons">
        <a href={site.sister.url} class="group-atenea-primary" rel="noopener">
          Conocer Ciberseguridad
          <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M10 7h7v7"/>
          </svg>
        </a>
        <a href="/servicios/#gestion-integral" class="group-atenea-secondary">Gestión integral</a>
      </div>
    </div>

    <div class="group-atenea-visual" aria-hidden="true">
      <div class="group-atenea-terminal">
        <div class="group-atenea-term-bar">
          <span></span><span></span><span></span>
          <span class="group-atenea-term-title">atenea@ciberseg: pentest</span>
        </div>
        <div class="group-atenea-term-body">
          <span class="line"><span class="prompt">$</span> <span class="cmd">atenea pentest</span> <span class="flag">--web --depth=full</span></span>
          <span class="line"><span class="info">[RECON]</span> <span class="output">Enumerating endpoints&hellip;</span></span>
          <span class="line"><span class="info">[SCAN]</span> <span class="output">187 URLs, 24 parameters</span></span>
          <span class="line"><span class="err">[CRIT]</span> <span class="output">SQLi in /admin/?id= (blind)</span></span>
          <span class="line"><span class="warn">[HIGH]</span> <span class="output">XSS stored in /profile</span></span>
          <span class="line"><span class="warn">[HIGH]</span> <span class="output">Missing CSP, X-Frame-Options</span></span>
          <span class="line"><span class="success">[FIX] &check;</span> <span class="output">Hardening propuesto (12 items)</span></span>
          <span class="line"><span class="prompt">$</span> <span class="cursor"></span></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .group-atenea-section {
    position: relative;
    padding: clamp(4rem, 7vw, 6.5rem) 1.5rem;
    background:
      radial-gradient(ellipse 60% 80% at 30% 35%, #8a0020 0%, transparent 62%),
      radial-gradient(ellipse 85% 100% at 75% 60%, #5a0014 0%, transparent 72%),
      #1a0006;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
  }
  .group-atenea-section::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 42px 42px;
    pointer-events: none;
    z-index: -1;
  }
  .group-atenea-section::after {
    content: "";
    position: absolute;
    width: 420px; height: 420px;
    top: -120px; right: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,120,140,0.28) 0%, transparent 65%);
    filter: blur(40px);
    z-index: -1;
    pointer-events: none;
  }

  .group-atenea-wrap {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .group-atenea-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono, monospace);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffd9b8;
    margin-bottom: 18px;
  }
  .group-atenea-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #ff5f57;
    box-shadow: 0 0 16px #ff5f57, 0 0 4px #ff5f57;
    animation: groupPulse 2.4s infinite;
  }
  @keyframes groupPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(1.2); }
  }

  .group-atenea-content h2 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 20px;
    font-weight: 700;
  }
  .group-atenea-content h2 em {
    font-style: italic;
    background: linear-gradient(90deg, #ffd9b8, #ff9bc1);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .group-atenea-lede {
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    font-size: 1rem;
    margin-bottom: 22px;
    max-width: 52ch;
  }
  .group-atenea-lede strong { color: #ffd9b8; font-weight: 600; }

  .group-atenea-feats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .group-atenea-feats span {
    padding: 6px 14px;
    border-radius: 100px;
    background: rgba(255, 217, 184, 0.08);
    border: 1px solid rgba(255, 217, 184, 0.24);
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: #ffe6d2;
  }

  .group-atenea-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .group-atenea-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    border-radius: 10px;
    background: linear-gradient(135deg, #a3001f 0%, #e4357f 100%);
    color: #fff;
    text-decoration: none;
    font-family: var(--font-mono, monospace);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 8px 24px rgba(163, 0, 31, 0.4);
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .group-atenea-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(228, 53, 127, 0.55);
  }
  .group-atenea-secondary {
    display: inline-flex;
    align-items: center;
    padding: 14px 26px;
    border-radius: 10px;
    border: 1px solid rgba(255, 217, 184, 0.25);
    background: transparent;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-mono, monospace);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.18s, border-color 0.18s;
  }
  .group-atenea-secondary:hover {
    background: rgba(255, 217, 184, 0.08);
    border-color: rgba(255, 217, 184, 0.5);
  }

  /* === TERMINAL hacker === */
  .group-atenea-visual {
    display: flex;
    justify-content: center;
  }
  .group-atenea-terminal {
    width: 100%;
    max-width: 480px;
    background: #0a0a0f;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 217, 184, 0.15);
    box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03) inset;
    transform: rotate(-1deg);
    transition: transform 0.4s;
  }
  .group-atenea-terminal:hover { transform: rotate(0deg) translateY(-4px); }
  .group-atenea-term-bar {
    background: rgba(255,255,255,0.04);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .group-atenea-term-bar > span:nth-child(-n+3) {
    width: 10px; height: 10px; border-radius: 50%;
    display: inline-block;
  }
  .group-atenea-term-bar > span:first-child { background: #ff5f57; }
  .group-atenea-term-bar > span:nth-child(2) { background: #febc2e; }
  .group-atenea-term-bar > span:nth-child(3) { background: #28c840; }
  .group-atenea-term-title {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    color: rgba(255,255,255,0.4);
    margin-left: 12px;
    letter-spacing: 0.04em;
  }
  .group-atenea-term-body {
    padding: 22px 20px;
    font-family: var(--font-mono, monospace);
    font-size: 0.76rem;
    line-height: 1.95;
    color: rgba(255,255,255,0.55);
    min-height: 260px;
  }
  .group-atenea-term-body .line {
    display: block;
    opacity: 0;
    animation: lineIn 0.4s forwards;
  }
  .group-atenea-term-body .line:nth-child(1) { animation-delay: 0.15s; }
  .group-atenea-term-body .line:nth-child(2) { animation-delay: 0.7s; }
  .group-atenea-term-body .line:nth-child(3) { animation-delay: 1.25s; }
  .group-atenea-term-body .line:nth-child(4) { animation-delay: 1.8s; }
  .group-atenea-term-body .line:nth-child(5) { animation-delay: 2.35s; }
  .group-atenea-term-body .line:nth-child(6) { animation-delay: 2.9s; }
  .group-atenea-term-body .line:nth-child(7) { animation-delay: 3.45s; }
  .group-atenea-term-body .line:nth-child(8) { animation-delay: 4s; }
  @keyframes lineIn { to { opacity: 1; } }

  .group-atenea-term-body .prompt { color: #28c840; }
  .group-atenea-term-body .cmd { color: rgba(255,255,255,0.9); }
  .group-atenea-term-body .flag { color: #f76ba4; }
  .group-atenea-term-body .output { color: rgba(255,255,255,0.4); }
  .group-atenea-term-body .success { color: #28c840; }
  .group-atenea-term-body .warn { color: #febc2e; }
  .group-atenea-term-body .info { color: #6eb4ff; }
  .group-atenea-term-body .err { color: #ff5f57; font-weight: 600; }
  .group-atenea-term-body .cursor {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: #ffd9b8;
    margin-left: 2px;
    vertical-align: middle;
    animation: cursorBlink 1s step-end infinite;
  }
  @keyframes cursorBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  @media (max-width: 900px) {
    .group-atenea-wrap {
      grid-template-columns: 1fr;
    }
    .group-atenea-visual {
      order: -1;
    }
  }
</style>
