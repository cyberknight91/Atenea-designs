---
import { nav, site } from '@lib/site';
---

<header class="nav" data-nav>
  <div class="container nav-inner">
    <a href="/" class="nav-brand" aria-label={`${site.name} — Inicio`}>
      <span class="nav-brand-mark"></span>
      <span class="nav-brand-text">Atenea Designs</span>
    </a>
    <nav class="nav-links" aria-label="Navegación principal">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="nav-actions">
      <a href={site.sister.url} class="sister-link" target="_blank" rel="noopener" aria-label={`Visitar ${site.sister.name}`} title={site.sister.blurb}>
        <span class="sister-dot" aria-hidden="true"></span>
        <span class="sister-text">{site.sister.name.replace('Atenea ', '')}</span>
        <svg class="sister-arrow" viewBox="0 0 24 24" aria-hidden="true" width="12" height="12">
          <path d="M7 17L17 7M10 7h7v7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <button class="theme-toggle" aria-label="Cambiar tema" data-theme-toggle>
        <svg class="sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <circle cx="12" cy="12" r="4" fill="currentColor"/>
          <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="12" y1="2"  x2="12" y2="5"/>
            <line x1="12" y1="19" x2="12" y2="22"/>
            <line x1="2"  y1="12" x2="5"  y2="12"/>
            <line x1="19" y1="12" x2="22" y2="12"/>
            <line x1="4.5" y1="4.5" x2="6.6" y2="6.6"/>
            <line x1="17.4" y1="17.4" x2="19.5" y2="19.5"/>
            <line x1="4.5" y1="19.5" x2="6.6" y2="17.4"/>
            <line x1="17.4" y1="6.6" x2="19.5" y2="4.5"/>
          </g>
        </svg>
        <svg class="moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" fill="currentColor"/>
        </svg>
      </button>
      <a href="/contacto/" class="btn btn-primary">Empezar proyecto</a>
      <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" data-nav-toggle>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <div class="nav-mobile" data-nav-mobile hidden>
    <ul>
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li><a href="/contacto/" class="btn btn-brand btn-lg">Empezar proyecto</a></li>
      <li>
        <a href={site.sister.url} class="sister-link sister-link-mobile" target="_blank" rel="noopener">
          <span class="sister-dot" aria-hidden="true"></span>
          <span>¿Buscas {site.sister.name}?</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
            <path d="M7 17L17 7M10 7h7v7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-2) var(--ease-out-expo), background var(--dur-2) var(--ease-out-expo);
  }
  .nav[data-scrolled] {
    border-bottom-color: var(--c-border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
    min-height: var(--nav-h);
  }
  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
  }
  .nav-brand-mark {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--gradient-brand);
    flex-shrink: 0;
  }
  .nav-brand-text {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .nav-brand-text { font-size: 1.05rem; }
  }

  .nav-links ul {
    display: flex;
    gap: var(--s-6);
  }
  .nav-links a {
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--ink-80);
    position: relative;
    padding-block: var(--s-2);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    height: 2px;
    width: 0;
    background: var(--gradient-brand);
    transition: width var(--dur-3) var(--ease-out-expo);
  }
  .nav-links a:hover::after { width: 100%; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  /* Sister-brand link (Ciberseguridad) */
  .sister-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: #7a0c0f;
    background: linear-gradient(135deg, rgba(136, 13, 16, 0.08), rgba(136, 13, 16, 0.12));
    border: 1px solid rgba(136, 13, 16, 0.22);
    border-radius: 999px;
    transition: transform var(--dur-2) var(--ease-spring), box-shadow var(--dur-2) var(--ease-out-expo), background var(--dur-1) var(--ease-out-expo), border-color var(--dur-1) var(--ease-out-expo);
  }
  .sister-link:hover {
    transform: translateY(-1px) scale(1.02);
    background: linear-gradient(135deg, rgba(136, 13, 16, 0.16), rgba(136, 13, 16, 0.22));
    border-color: rgba(136, 13, 16, 0.45);
    box-shadow: 0 10px 24px -10px rgba(136, 13, 16, 0.55);
    color: #5c0809;
  }
  .sister-link:hover .sister-arrow { transform: translate(2px, -2px); }
  .sister-link:hover .sister-dot   { transform: scale(1.3); box-shadow: 0 0 12px rgba(136, 13, 16, 0.7); }

  .sister-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #880D10;
    box-shadow: 0 0 6px rgba(136, 13, 16, 0.5);
    flex-shrink: 0;
    transition: transform var(--dur-2) var(--ease-spring), box-shadow var(--dur-2) var(--ease-out-expo);
  }
  .sister-arrow {
    transition: transform var(--dur-2) var(--ease-spring);
    flex-shrink: 0;
  }
  :global([data-theme='dark']) .sister-link {
    color: #ff9a9e;
    background: linear-gradient(135deg, rgba(229, 115, 120, 0.08), rgba(229, 115, 120, 0.14));
    border-color: rgba(229, 115, 120, 0.28);
  }
  :global([data-theme='dark']) .sister-link:hover {
    color: #ffb8bc;
    background: linear-gradient(135deg, rgba(229, 115, 120, 0.18), rgba(229, 115, 120, 0.26));
    border-color: rgba(229, 115, 120, 0.5);
  }
  :global([data-theme='dark']) .sister-dot {
    background: #e57378;
    box-shadow: 0 0 6px rgba(229, 115, 120, 0.6);
  }

  .sister-link-mobile {
    justify-content: center;
    padding: var(--s-3) var(--s-5);
    font-size: var(--fs-base);
    margin-top: var(--s-2);
  }

  .theme-toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--dur-2) var(--ease-out-expo), transform var(--dur-2) var(--ease-spring);
  }
  .theme-toggle:hover {
    background: var(--c-bg-elev);
    transform: rotate(15deg);
  }
  .theme-toggle .moon { display: none; }
  :global([data-theme='dark']) .theme-toggle .sun { display: none; }
  :global([data-theme='dark']) .theme-toggle .moon { display: block; }

  .nav-toggle {
    display: none;
    width: 44px; height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .nav-toggle span {
    display: block;
    width: 22px; height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform var(--dur-2) var(--ease-out-expo), opacity var(--dur-1);
  }
  .nav[data-open] .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav[data-open] .nav-toggle span:nth-child(2) { opacity: 0; }
  .nav[data-open] .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    display: none;
    padding: var(--s-5);
    border-top: 1px solid var(--c-border);
  }
  .nav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .nav-mobile a {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
  }

  @media (max-width: 860px) {
    .nav-links { display: none; }
    .nav-toggle { display: inline-flex; }
    .nav-actions .btn { display: none; }
    .nav-actions .sister-link { display: none; }
    .nav[data-open] .nav-mobile { display: block; }
  }
</style>

<script>
  const navEl = document.querySelector<HTMLElement>('[data-nav]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const mobile = document.querySelector<HTMLElement>('[data-nav-mobile]');
  const themeBtn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch {}
  });
  if (navEl && toggle && mobile) {
    toggle.addEventListener('click', () => {
      const open = navEl.hasAttribute('data-open');
      if (open) {
        navEl.removeAttribute('data-open');
        mobile.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menú');
      } else {
        navEl.setAttribute('data-open', '');
        mobile.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Cerrar menú');
      }
    });
    const onScroll = () => {
      if (window.scrollY > 8) navEl.setAttribute('data-scrolled', '');
      else navEl.removeAttribute('data-scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
